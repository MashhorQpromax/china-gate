# China Gate Authentication System Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# WeChat OAuth (Chinese supplier authentication)
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# Email Service (for password reset, verification)
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your_sendgrid_key_here
EMAIL_FROM=noreply@chinagate.com

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_STORAGE=local
# UPLOAD_STORAGE=s3 (for AWS S3)
# AWS_S3_BUCKET=china-gate-uploads
# AWS_S3_REGION=us-east-1

# Session & Authentication
SESSION_SECRET=your_session_secret_key_here_min_32_chars
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRY=7d

# Database (for future implementation)
# DATABASE_URL=postgresql://user:password@localhost:5432/china_gate

# Logging
LOG_LEVEL=info
NODE_ENV=development
